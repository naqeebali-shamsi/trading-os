# Trading OS runtime configuration (written by install wizard)
# Copy to %ProgramData%\TradingOS\config.env or repo root as config.env

TRADING_OS_ROOT=C:\TradingOS
TRADING_OS_IPC=C:\TradingOS\ipc
TRADING_OS_MODE=SIMULATION
TRADING_OS_LLM_DECISION_MODE=ADVISORY
TRADING_OS_DASHBOARD_PORT=8765
TRADING_OS_DASHBOARD_URL=http://127.0.0.1:8765/ui

# Optional — prefer secrets.yaml for API keys
# OPENROUTER_API_KEY=
